generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  USER
  ADMIN
}

enum WatchStatus {
  PLANNING
  WATCHING
  COMPLETED
  DROPPED
}

// ==================== MODELS ====================

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String  @unique
  passwordHash String
  avatar       String?
  role         Role    @default(USER)
  refreshToken String?

  reviews   Review[]
  favorites Favorite[]
  watchlist Watchlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Movie {
  id          String    @id @default(uuid())
  tmdbId      Int?      @unique
  title       String
  overview    String
  poster      String?
  backdrop    String?
  releaseDate DateTime?
  duration    Int?
  rating      Float     @default(0)
  ratingCount Int       @default(0)

  genres    Genre[]     @relation("MovieGenres")
  reviews   Review[]
  favorites Favorite[]
  watchlist Watchlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("movies")
}

model Genre {
  id     String @id @default(uuid())
  name   String @unique
  tmdbId Int?   @unique

  movies Movie[] @relation("MovieGenres")

  @@map("genres")
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  userId  String
  movieId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId])
  @@map("reviews")
}

model Favorite {
  id      String @id @default(uuid())
  userId  String
  movieId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, movieId])
  @@map("favorites")
}

model Watchlist {
  id      String      @id @default(uuid())
  status  WatchStatus @default(PLANNING)
  userId  String
  movieId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId])
  @@map("watchlist")
}